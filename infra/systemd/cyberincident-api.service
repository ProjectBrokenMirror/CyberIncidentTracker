[Unit]
Description=Cyber Incident Tracker API
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/apps/CyberIncidentTracker/backend
EnvironmentFile=/root/apps/CyberIncidentTracker/backend/.env
ExecStart=/root/apps/CyberIncidentTracker/backend/.venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
