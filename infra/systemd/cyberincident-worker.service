[Unit]
Description=Cyber Incident Tracker Celery Worker
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/apps/CyberIncidentTracker/backend
EnvironmentFile=/root/apps/CyberIncidentTracker/backend/.env
ExecStart=/root/apps/CyberIncidentTracker/backend/.venv/bin/celery -A app.tasks.worker.celery_app worker --loglevel=info
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
