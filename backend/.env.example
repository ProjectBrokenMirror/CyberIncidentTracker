APP_ENV=development
APP_NAME=Cyber Incident Tracker API
DATABASE_URL=postgresql+psycopg://incident_user:incident_pass@localhost:5432/incident_tracker
REDIS_URL=redis://localhost:6379/0
API_V1_PREFIX=/api/v1
DATABREACHES_FEED_URL=https://www.databreaches.net/feed/
HHS_OCR_FRONTPAGE_URL=https://ocrportal.hhs.gov/ocr/breach/breach_frontpage.jsf
HHS_OCR_REPORT_URL=https://ocrportal.hhs.gov/ocr/breach/breach_report_hip.jsf
SEC_8K_FEED_URL=https://www.sec.gov/cgi-bin/browse-edgar?action=getcurrent&type=8-k&company=&dateb=&owner=include&start=0&count=100&output=atom
SEC_USER_AGENT=IncidentFinder/0.1 (security-research@example.com)
CONNECTOR_MAX_RECORDS=50
AUTO_CREATE_ORG_SOURCES=sec_edgar_8k,hhs_ocr
REQUIRE_API_KEY=false
API_KEYS=
DEFAULT_TENANT_ID=default
ENABLE_EMAIL_ALERTS=false
SMTP_HOST=localhost
SMTP_PORT=25
SMTP_USE_TLS=false
SMTP_USERNAME=
SMTP_PASSWORD=
ALERTS_FROM_EMAIL=alerts@incidentfinder.local
ALERT_RETRY_MAX_ATTEMPTS=3
ALERT_RETRY_BACKOFF_SECONDS=60
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
TRUSTED_HOSTS=localhost,127.0.0.1,testserver
